# ─────────────────────────────────────────────────────────────────
#  CorpEMD — Environment Variables
#  Copy this file to .env and fill in every value before starting.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=corpemd
POSTGRES_USER=corpemd
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_byte_hex_string

# ── Google Cloud / Android Management API ─────────────────────────
# Service account JSON — minified to a single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nKEY_CONTENT\n-----END PRIVATE KEY-----\n","client_email":"corpemd@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Enterprise ID from the AMAPI signup flow  (looks like: LC0xxxxxxxxxxxx)
AMAPI_ENTERPRISE_ID=LC0xxxxxxxxxxxx
AMAPI_ENTERPRISE_NAME=enterprises/LC0xxxxxxxxxxxx

# Pub/Sub subscription name for device events
PUBSUB_SUBSCRIPTION=corpemd-device-events

# ── App ───────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
HTTP_PORT=80
HTTPS_PORT=443
LOG_LEVEL=info
NODE_ENV=development
PORT=3000
